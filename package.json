{
  "name": "viewstor",
  "displayName": "Viewstor",
  "description": "%extension.description%",
  "version": "0.2.1",
  "publisher": "Siyet",
  "license": "AGPL-3.0",
  "icon": "resources/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Siyet/viewstor"
  },
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": [
    "Other",
    "Data Science"
  ],
  "keywords": [
    "database",
    "postgresql",
    "redis",
    "clickhouse",
    "sql",
    "query",
    "schema"
  ],
  "l10n": "./l10n",
  "main": "./dist/extension.js",
  "bin": {
    "viewstor-mcp": "./dist/mcp-server.js"
  },
  "scripts": {
    "vscode:prepublish": "npm run copy-nls && npm run build",
    "postinstall": "npm run copy-nls",
    "copy-nls": "node -e \"fs=require('fs');p=require('path');d='l10n/nls';fs.readdirSync(d).filter(f=>f.startsWith('package.nls')).forEach(f=>fs.copyFileSync(p.join(d,f),f))\"",
    "build": "npm run copy-nls && webpack --mode production",
    "watch": "npm run copy-nls && webpack --mode development --watch",
    "dev": "npm run copy-nls && webpack --mode development",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:single": "vitest run --reporter=verbose",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:e2e:watch": "vitest --config vitest.e2e.config.ts",
    "compile-tests": "tsc -p tsconfig.test.json",
    "package": "vsce package"
  },
  "contributes": {
    "chatParticipants": [
      {
        "id": "viewstor.chat",
        "fullName": "Viewstor",
        "name": "viewstor",
        "description": "%chat.description%",
        "isSticky": true,
        "commands": [
          {
            "name": "schema",
            "description": "%chat.command.schema%"
          },
          {
            "name": "query",
            "description": "%chat.command.query%"
          },
          {
            "name": "describe",
            "description": "%chat.command.describe%"
          }
        ]
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "viewstor",
          "title": "Viewstor",
          "icon": "resources/icon-sidebar.svg"
        }
      ]
    },
    "views": {
      "viewstor": [
        {
          "id": "viewstor.connections",
          "name": "%view.connections.name%"
        },
        {
          "id": "viewstor.queryHistory",
          "name": "%view.queryHistory.name%"
        }
      ]
    },
    "commands": [
      {
        "command": "viewstor.addConnection",
        "title": "%command.addConnection%",
        "category": "Viewstor",
        "icon": "$(add)"
      },
      {
        "command": "viewstor.removeConnection",
        "title": "%command.removeConnection%",
        "category": "Viewstor",
        "icon": "$(trash)"
      },
      {
        "command": "viewstor.editConnection",
        "title": "%command.editConnection%",
        "category": "Viewstor"
      },
      {
        "command": "viewstor.connect",
        "title": "%command.connect%",
        "category": "Viewstor",
        "icon": "$(plug)"
      },
      {
        "command": "viewstor.disconnect",
        "title": "%command.disconnect%",
        "category": "Viewstor",
        "icon": "$(debug-disconnect)"
      },
      {
        "command": "viewstor.refreshConnection",
        "title": "%command.refresh%",
        "category": "Viewstor",
        "icon": "$(refresh)"
      },
      {
        "command": "viewstor.openQuery",
        "title": "%command.openQuery%",
        "category": "Viewstor",
        "icon": "$(file-code)"
      },
      {
        "command": "viewstor.runQuery",
        "title": "%command.runQuery%",
        "category": "Viewstor",
        "icon": "$(play)"
      },
      {
        "command": "viewstor.exportResults",
        "title": "%command.exportResults%",
        "category": "Viewstor"
      },
      {
        "command": "viewstor.showTableData",
        "title": "%command.showTableData%",
        "category": "Viewstor"
      },
      {
        "command": "viewstor.showDDL",
        "title": "%command.showDDL%",
        "category": "Viewstor"
      },
      {
        "command": "viewstor.createFolder",
        "title": "%command.createFolder%",
        "category": "Viewstor",
        "icon": "$(new-folder)"
      },
      {
        "command": "viewstor.editFolder",
        "title": "%command.editFolder%",
        "category": "Viewstor"
      },
      {
        "command": "viewstor.importConnections",
        "title": "%command.importConnections%",
        "category": "Viewstor",
        "icon": "$(cloud-download)"
      },
      {
        "command": "viewstor.hideSchema",
        "title": "%command.hideSchema%",
        "category": "Viewstor",
        "icon": "$(eye-closed)"
      },
      {
        "command": "viewstor.hideDatabase",
        "title": "%command.hideDatabase%",
        "category": "Viewstor"
      },
      {
        "command": "viewstor.showAllSchemas",
        "title": "%command.showAllSchemas%",
        "category": "Viewstor"
      },
      {
        "command": "viewstor.reportIssue",
        "title": "%command.reportIssue%",
        "category": "Viewstor",
        "icon": "$(github)"
      },
      {
        "command": "viewstor.copyName",
        "title": "%command.copyName%",
        "category": "Viewstor"
      },
      {
        "command": "viewstor.renameObject",
        "title": "%command.renameObject%",
        "category": "Viewstor"
      },
      {
        "command": "viewstor.createObject",
        "title": "%command.createObject%",
        "category": "Viewstor"
      },
      {
        "command": "viewstor.dropObject",
        "title": "%command.dropObject%",
        "category": "Viewstor"
      },
      {
        "command": "viewstor.deleteFolder",
        "title": "%command.deleteFolder%",
        "category": "Viewstor"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "viewstor.addConnection",
          "when": "view == viewstor.connections",
          "group": "navigation"
        },
        {
          "command": "viewstor.createFolder",
          "when": "view == viewstor.connections",
          "group": "navigation"
        },
        {
          "command": "viewstor.importConnections",
          "when": "view == viewstor.connections",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "viewstor.refreshConnection",
          "when": "view == viewstor.connections && viewItem == connection-connected",
          "group": "inline"
        },
        {
          "command": "viewstor.openQuery",
          "when": "view == viewstor.connections && viewItem =~ /^connection-/",
          "group": "1_query"
        },
        {
          "command": "viewstor.openQuery",
          "when": "view == viewstor.connections && viewItem =~ /^(table|view|schema|database)$/",
          "group": "1_query"
        },
        {
          "command": "viewstor.showTableData",
          "when": "view == viewstor.connections && viewItem =~ /^(table|view)$/",
          "group": "2_data"
        },
        {
          "command": "viewstor.showDDL",
          "when": "view == viewstor.connections && viewItem =~ /^(table|view|index|trigger|sequence)$/",
          "group": "2_data"
        },
        {
          "command": "viewstor.copyName",
          "when": "view == viewstor.connections && viewItem =~ /^(table|view|column|index|trigger|sequence|schema|database)$/",
          "group": "2_data"
        },
        {
          "command": "viewstor.renameObject",
          "when": "view == viewstor.connections && viewItem =~ /^(table|view|index|sequence|column|schema|database)$/",
          "group": "2_data"
        },
        {
          "command": "viewstor.createObject",
          "when": "view == viewstor.connections && viewItem =~ /^(connection-connected|database|schema|table|group)$/",
          "group": "2_data"
        },
        {
          "command": "viewstor.dropObject",
          "when": "view == viewstor.connections && viewItem =~ /^(table|view|index|trigger|sequence|schema|database)$/",
          "group": "4_danger"
        },
        {
          "command": "viewstor.hideSchema",
          "when": "view == viewstor.connections && viewItem == schema",
          "group": "3_manage"
        },
        {
          "command": "viewstor.hideDatabase",
          "when": "view == viewstor.connections && viewItem == database",
          "group": "3_manage"
        },
        {
          "command": "viewstor.showAllSchemas",
          "when": "view == viewstor.connections && viewItem =~ /^connection-/",
          "group": "3_manage"
        },
        {
          "command": "viewstor.disconnect",
          "when": "view == viewstor.connections && viewItem == connection-connected",
          "group": "3_manage"
        },
        {
          "command": "viewstor.removeConnection",
          "when": "view == viewstor.connections && viewItem =~ /^connection-/",
          "group": "3_manage"
        },
        {
          "command": "viewstor.editConnection",
          "when": "view == viewstor.connections && viewItem =~ /^connection-/",
          "group": "3_manage"
        },
        {
          "command": "viewstor.addConnection",
          "when": "view == viewstor.connections && viewItem == folder",
          "group": "1_query"
        },
        {
          "command": "viewstor.createFolder",
          "when": "view == viewstor.connections && viewItem == folder",
          "group": "1_query"
        },
        {
          "command": "viewstor.editFolder",
          "when": "view == viewstor.connections && viewItem == folder",
          "group": "1_query"
        },
        {
          "command": "viewstor.deleteFolder",
          "when": "view == viewstor.connections && viewItem == folder",
          "group": "3_manage"
        }
      ]
    },
    "configuration": {
      "title": "Viewstor",
      "properties": {
        "viewstor.defaultPageSize": {
          "type": "number",
          "default": 100,
          "enum": [
            50,
            100,
            500,
            1000
          ],
          "description": "%config.defaultPageSize.description%"
        },
        "viewstor.safeMode": {
          "type": "string",
          "default": "warn",
          "enum": [
            "off",
            "warn",
            "block"
          ],
          "enumDescriptions": [
            "%config.safeMode.off%",
            "%config.safeMode.warn%",
            "%config.safeMode.block%"
          ],
          "description": "%config.safeMode.description%"
        },
        "viewstor.indexHintThreshold": {
          "type": "number",
          "default": 100000,
          "description": "%config.indexHintThreshold.description%"
        },
        "viewstor.confirmEdits": {
          "type": "boolean",
          "default": true,
          "description": "%config.confirmEdits.description%"
        }
      }
    },
    "keybindings": [
      {
        "command": "viewstor.runQuery",
        "key": "ctrl+enter",
        "mac": "cmd+enter",
        "when": "editorTextFocus && editorLangId == sql"
      }
    ],
    "languages": [
      {
        "id": "viewstor-sql",
        "aliases": [
          "Viewstor SQL"
        ],
        "extensions": [
          ".vsql"
        ]
      }
    ]
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/pg": "^8.20.0",
    "@types/ssh2": "^1.15.5",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vscode/vsce": "^2.22.0",
    "copy-webpack-plugin": "^12.0.0",
    "css-loader": "^6.10.0",
    "eslint": "^8.56.0",
    "style-loader": "^3.3.4",
    "testcontainers": "^11.13.0",
    "ts-loader": "^9.5.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.0"
  },
  "dependencies": {
    "@clickhouse/client": "^0.2.0",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "ioredis": "^5.3.0",
    "pg": "^8.11.0",
    "ssh2": "^1.17.0"
  }
}
